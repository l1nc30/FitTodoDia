<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Banco Room com todos os treinos, histórico e progresso -->
        <include domain="database" path="fittododia.db" />
        <include domain="database" path="fittododia.db-shm" />
        <include domain="database" path="fittododia.db-wal" />
        <!-- DataStore (tema, lembretes) -->
        <include domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="fittododia.db" />
        <include domain="database" path="fittododia.db-shm" />
        <include domain="database" path="fittododia.db-wal" />
        <include domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
